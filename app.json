{
  "expo": {
    "name": "Solviva",
    "slug": "solviva-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#C8E600",
      "resizeMode": "contain",
      "image": "./assets/splash-icon.png"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.solviva.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C8E600"
      },
      "package": "com.solviva.app"
    },
    "updates": {
      "enabled": false
    },
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro",
      "output": "single",
      "name": "Solviva",
      "baseUrl": "/mobile-app"
    },
    "extra": {
      "SUPABASE_URL": "https://kzsocvzhbgtfyksrjmvk.supabase.co",
      "SUPABASE_ANON_KEY": "dummy-key"
    },
    "plugins": ["expo-asset"]
  }
}
